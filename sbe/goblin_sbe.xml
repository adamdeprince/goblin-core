<?xml version="1.0" encoding="UTF-8"?>
<!--
  Goblin Core SBE (Simple Binary Encoding) wire schema - the binary alternative to
  RESP, switched on by the GOBL magic. Codegen is a maintainer step (like
  `capnp compile` / gperf): run SbeTool on this file to regenerate the header-only
  C++ codecs under sbe/generated/. Ordinary builds only compile the generated
  headers - SBE C++ has no runtime library.

  BACKWARD-COMPATIBLE EXTENSION (goblin adds commands weekly - this is the rule):
    * templateId is a PERMANENT command id. A new command takes the next unused id,
      APPENDED. Never renumber, never reuse a retired id. This file is the ledger.
    * Fields within a message are APPEND-ONLY: a new arg is appended (a fixed field
      after the block, or a group / var-data after the existing ones) tagged
      sinceVersion="V". SBE decoders read the wire's blockLength and skip anything
      they do not know, so a new server and an old client interoperate untouched.
    * Bump the schema `version` on each additive change.
    * Replies are a small fixed generic set reused by every command, so adding a
      command is usually one request message + one handler + one test line.

  ID PLAN:
    * Reply messages (server -> client): ids 1-15 (generic, reused everywhere).
    * Request messages (client -> server): ids 16+, appended densely so the
      server's templateId switch compiles to a jump table.
-->
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="goblin_sbe"
                   id="7"
                   version="0"
                   semanticVersion="1.0"
                   description="Goblin Core SBE wire (binary alternative to RESP)"
                   byteOrder="littleEndian">
  <types>
    <composite name="messageHeader" description="SBE message header (8 bytes)">
      <type name="blockLength" primitiveType="uint16"/>
      <type name="templateId"  primitiveType="uint16"/>
      <type name="schemaId"    primitiveType="uint16"/>
      <type name="version"     primitiveType="uint16"/>
    </composite>
    <composite name="groupSizeEncoding" description="repeating-group dimensions">
      <type name="blockLength" primitiveType="uint16"/>
      <!-- SBE caps numInGroup at uint16 (65535 elements per group). A reply larger
           than that (a huge-leaderboard ZRANGE 0 -1) must paginate/chunk; the
           dispatch guards against overflow rather than truncating silently. -->
      <type name="numInGroup"  primitiveType="uint16"/>
    </composite>
    <composite name="varData" description="variable-length byte string (binary-safe)">
      <type name="length"  primitiveType="uint32" maxValue="1073741824"/>
      <type name="varData" primitiveType="uint8" length="0"/>
    </composite>
  </types>

  <!-- ================= Reply messages (ids 1-15, generic, reused) ================= -->
  <!-- The vocabulary command.cpp actually emits: error / integer / bulk / null-bulk /
       simple-string / array / withscores. Doubles ride native (no restringify).
       Reserved-but-not-yet-defined: BulkReply=6 (added with the first command that
       returns a single bulk string, e.g. GET). -->
  <sbe:message name="NilReply"    id="1" description="null bulk (key/member absent)"/>
  <sbe:message name="StatusReply" id="2" description="simple string, e.g. OK / PONG">
    <data name="status" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="ErrorReply"  id="3" description="error code + message">
    <data name="code"    id="1" type="varData"/>
    <data name="message" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="IntReply"    id="4" description="integer reply">
    <field name="value" id="1" type="int64"/>
  </sbe:message>
  <sbe:message name="DoubleReply" id="5" description="native double reply (e.g. ZSCORE)">
    <field name="value" id="1" type="double"/>
  </sbe:message>
  <sbe:message name="BulkReply"   id="6" description="one bulk string (e.g. GET)">
    <data name="value" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="ArrayReply"  id="7" description="array of bulk strings (e.g. ZRANGE)">
    <group name="items" id="1" dimensionType="groupSizeEncoding">
      <data name="value" id="1" type="varData"/>
    </group>
  </sbe:message>
  <sbe:message name="ScoredArrayReply" id="8" description="(member, native score) pairs (ZRANGE WITHSCORES)">
    <group name="items" id="1" dimensionType="groupSizeEncoding">
      <field name="score"  id="1" type="double"/>
      <data  name="member" id="2" type="varData"/>
    </group>
  </sbe:message>
  <sbe:message name="NullableArrayReply" id="9" description="array whose elements may be nil (HMGET/MGET)">
    <group name="items" id="1" dimensionType="groupSizeEncoding">
      <field name="present" id="1" type="uint8"/>
      <data  name="value"   id="2" type="varData"/>
    </group>
  </sbe:message>
  <!-- A script's arbitrary, possibly nested RESP result. SBE groups do not nest
       arbitrarily, so the tree is flattened into a pre-order node sequence: each
       array/map node declares childCount direct children that follow it. type:
       0 nil, 1 int(intValue), 2 bulk(bytes), 3 status(bytes), 4 error(bytes),
       5 array(childCount), 6 map(childCount pairs -> 2*childCount child nodes). -->
  <sbe:message name="RespValueReply" id="10" description="flattened RESP tree (EVAL / EVALSHA)">
    <group name="nodes" id="1" dimensionType="groupSizeEncoding">
      <field name="type"       id="1" type="uint8"/>
      <field name="intValue"   id="2" type="int64"/>
      <field name="childCount" id="3" type="uint32"/>
      <data  name="bytes"      id="4" type="varData"/>
    </group>
  </sbe:message>
  <sbe:message name="MapReply" id="11" description="key/value pairs (e.g. GOBLIN.MEMORY)">
    <group name="entries" id="1" dimensionType="groupSizeEncoding">
      <data name="key"   id="1" type="varData"/>
      <data name="value" id="2" type="varData"/>
    </group>
  </sbe:message>

  <!-- ================= Request messages (ids 16+, appended densely) ============== -->
  <sbe:message name="Ping" id="16" description="PING -> StatusReply PONG"/>

  <!-- ZADD key [score member]... : flags byte, members group, then the key. -->
  <sbe:message name="ZAdd" id="17" description="ZADD key [score member]... -> IntReply">
    <field name="flags" id="1" type="uint8"/>
    <group name="members" id="2" dimensionType="groupSizeEncoding">
      <field name="score" id="1" type="double"/>
      <data  name="member" id="2" type="varData"/>
    </group>
    <data name="key" id="3" type="varData"/>
  </sbe:message>

  <sbe:message name="ZCard" id="18" description="ZCARD key -> IntReply">
    <data name="key" id="1" type="varData"/>
  </sbe:message>

  <sbe:message name="ZScore" id="19" description="ZSCORE key member -> DoubleReply | NilReply">
    <data name="key"    id="1" type="varData"/>
    <data name="member" id="2" type="varData"/>
  </sbe:message>

  <sbe:message name="ZRank" id="20" description="ZRANK key member -> IntReply | NilReply">
    <data name="key"    id="1" type="varData"/>
    <data name="member" id="2" type="varData"/>
  </sbe:message>

  <!-- ZRANGE key start stop [WITHSCORES]: fixed block (start, stop, flags) then key.
       withScores=0 -> ArrayReply; withScores=1 -> ScoredArrayReply (native doubles).
       The `rev` flag folds in ZREVRANGE. -->
  <sbe:message name="ZRange" id="21" description="ZRANGE/ZREVRANGE key start stop [WITHSCORES]">
    <field name="start"      id="1" type="int64"/>
    <field name="stop"       id="2" type="int64"/>
    <field name="withScores" id="3" type="uint8"/>
    <field name="rev"        id="4" type="uint8"/>
    <data  name="key"        id="5" type="varData"/>
  </sbe:message>

  <!-- ===================== String commands (batch 1, ids 22-33) ================= -->
  <sbe:message name="Get"    id="22" description="GET key -> BulkReply | NilReply">
    <data name="key" id="1" type="varData"/>
  </sbe:message>

  <!-- SET key value [NX|XX] [GET] [EX|PX|EXAT|PXAT n | KEEPTTL]. flags bits:
       0x01 NX, 0x02 XX, 0x04 GET, 0x08 KEEPTTL. expireMode: 0 none, 1 EX, 2 PX,
       3 EXAT, 4 PXAT (expireValue is the amount). -> StatusReply | BulkReply | NilReply -->
  <sbe:message name="Set" id="23" description="SET key value [opts]">
    <field name="flags"       id="1" type="uint8"/>
    <field name="expireMode"  id="2" type="uint8"/>
    <field name="expireValue" id="3" type="int64"/>
    <data  name="key"         id="4" type="varData"/>
    <data  name="value"       id="5" type="varData"/>
  </sbe:message>

  <sbe:message name="GetSet" id="24" description="GETSET key value -> BulkReply | NilReply">
    <data name="key"   id="1" type="varData"/>
    <data name="value" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="SetNx"  id="25" description="SETNX key value -> IntReply">
    <data name="key"   id="1" type="varData"/>
    <data name="value" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="GetDel" id="26" description="GETDEL key -> BulkReply | NilReply">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="StrLen" id="27" description="STRLEN key -> IntReply">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="Append" id="28" description="APPEND key value -> IntReply">
    <data name="key"   id="1" type="varData"/>
    <data name="value" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="Incr"   id="29" description="INCR key -> IntReply | ErrorReply">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="Decr"   id="30" description="DECR key -> IntReply | ErrorReply">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="IncrBy" id="31" description="INCRBY key delta -> IntReply | ErrorReply">
    <field name="delta" id="1" type="int64"/>
    <data  name="key"   id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="DecrBy" id="32" description="DECRBY key delta -> IntReply | ErrorReply">
    <field name="delta" id="1" type="int64"/>
    <data  name="key"   id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="IncrByFloat" id="33" description="INCRBYFLOAT key delta -> BulkReply | ErrorReply">
    <field name="delta" id="1" type="double"/>
    <data  name="key"   id="2" type="varData"/>
  </sbe:message>

  <!-- ===================== Keyspace / TTL (batch 2, ids 34-45) ================== -->
  <sbe:message name="Del"    id="34" description="DEL key... -> IntReply (count removed)">
    <group name="keys" id="1" dimensionType="groupSizeEncoding">
      <data name="key" id="1" type="varData"/>
    </group>
  </sbe:message>
  <sbe:message name="Exists" id="35" description="EXISTS key... -> IntReply (count present)">
    <group name="keys" id="1" dimensionType="groupSizeEncoding">
      <data name="key" id="1" type="varData"/>
    </group>
  </sbe:message>
  <sbe:message name="Type"   id="36" description="TYPE key -> StatusReply (string/zset/hash/none)">
    <data name="key" id="1" type="varData"/>
  </sbe:message>

  <!-- EXPIRE family: native amount + flags (0x01 NX, 0x02 XX, 0x04 GT, 0x08 LT,
       matching store.hpp ExpireFlag). EXPIRE/EXPIREAT are seconds, PEXPIRE/PEXPIREAT
       milliseconds; the *AT variants are absolute. -> IntReply | ErrorReply. -->
  <sbe:message name="Expire"    id="37" description="EXPIRE key seconds [flags]">
    <field name="amount" id="1" type="int64"/>
    <field name="flags"  id="2" type="uint8"/>
    <data  name="key"    id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="PExpire"   id="38" description="PEXPIRE key ms [flags]">
    <field name="amount" id="1" type="int64"/>
    <field name="flags"  id="2" type="uint8"/>
    <data  name="key"    id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="ExpireAt"  id="39" description="EXPIREAT key ts-seconds [flags]">
    <field name="amount" id="1" type="int64"/>
    <field name="flags"  id="2" type="uint8"/>
    <data  name="key"    id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="PExpireAt" id="40" description="PEXPIREAT key ts-ms [flags]">
    <field name="amount" id="1" type="int64"/>
    <field name="flags"  id="2" type="uint8"/>
    <data  name="key"    id="3" type="varData"/>
  </sbe:message>

  <sbe:message name="Ttl"         id="41" description="TTL key -> IntReply (seconds; -1/-2)">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="PTtl"        id="42" description="PTTL key -> IntReply (ms; -1/-2)">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="Persist"     id="43" description="PERSIST key -> IntReply (0/1)">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="ExpireTime"  id="44" description="EXPIRETIME key -> IntReply (unix seconds; -1/-2)">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="PExpireTime" id="45" description="PEXPIRETIME key -> IntReply (unix ms; -1/-2)">
    <data name="key" id="1" type="varData"/>
  </sbe:message>

  <!-- ========================= Hash commands (batch 3, ids 46-57) =============== -->
  <!-- HSET key [field value]...: a group of (field, value) then the key (like ZADD). -->
  <sbe:message name="HSet" id="46" description="HSET key [field value]... -> IntReply">
    <group name="entries" id="1" dimensionType="groupSizeEncoding">
      <data name="field" id="1" type="varData"/>
      <data name="value" id="2" type="varData"/>
    </group>
    <data name="key" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="HSetNx" id="47" description="HSETNX key field value -> IntReply">
    <data name="key"   id="1" type="varData"/>
    <data name="field" id="2" type="varData"/>
    <data name="value" id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="HGet" id="48" description="HGET key field -> BulkReply | NilReply">
    <data name="key"   id="1" type="varData"/>
    <data name="field" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="HMGet" id="49" description="HMGET key field... -> NullableArrayReply">
    <group name="fields" id="1" dimensionType="groupSizeEncoding">
      <data name="field" id="1" type="varData"/>
    </group>
    <data name="key" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="HDel" id="50" description="HDEL key field... -> IntReply (count removed)">
    <group name="fields" id="1" dimensionType="groupSizeEncoding">
      <data name="field" id="1" type="varData"/>
    </group>
    <data name="key" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="HGetAll" id="51" description="HGETALL key -> ArrayReply [field value]...">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="HKeys" id="52" description="HKEYS key -> ArrayReply of fields">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="HVals" id="53" description="HVALS key -> ArrayReply of values">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="HLen" id="54" description="HLEN key -> IntReply">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="HExists" id="55" description="HEXISTS key field -> IntReply (0/1)">
    <data name="key"   id="1" type="varData"/>
    <data name="field" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="HStrLen" id="56" description="HSTRLEN key field -> IntReply">
    <data name="key"   id="1" type="varData"/>
    <data name="field" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="HIncrBy" id="57" description="HINCRBY key field delta -> IntReply | ErrorReply">
    <field name="delta" id="1" type="int64"/>
    <data  name="key"   id="2" type="varData"/>
    <data  name="field" id="3" type="varData"/>
  </sbe:message>

  <!-- ================ Standard-command tail (batch 4, ids 58-65) ================ -->
  <sbe:message name="ZRevRank" id="58" description="ZREVRANK key member -> IntReply | NilReply">
    <data name="key"    id="1" type="varData"/>
    <data name="member" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="ZRem" id="59" description="ZREM key member... -> IntReply (count removed)">
    <group name="members" id="1" dimensionType="groupSizeEncoding">
      <data name="member" id="1" type="varData"/>
    </group>
    <data name="key" id="2" type="varData"/>
  </sbe:message>
  <!-- Native score bounds (min/max may be +/-inf); the exclusive flags are the "("
       markers RESP parses from the ASCII form. -> IntReply -->
  <sbe:message name="ZRemRangeByScore" id="60" description="ZREMRANGEBYSCORE key min max">
    <field name="min"          id="1" type="double"/>
    <field name="minExclusive" id="2" type="uint8"/>
    <field name="max"          id="3" type="double"/>
    <field name="maxExclusive" id="4" type="uint8"/>
    <data  name="key"          id="5" type="varData"/>
  </sbe:message>

  <sbe:message name="GetRange" id="61" description="GETRANGE key start end -> BulkReply">
    <field name="start" id="1" type="int64"/>
    <field name="end"   id="2" type="int64"/>
    <data  name="key"   id="3" type="varData"/>
  </sbe:message>
  <!-- `byteOffset` not `offset`: SBE flyweights already have a built-in offset(). -->
  <sbe:message name="SetRange" id="62" description="SETRANGE key offset value -> IntReply | ErrorReply">
    <field name="byteOffset" id="1" type="int64"/>
    <data  name="key"        id="2" type="varData"/>
    <data  name="value"      id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="MSet" id="63" description="MSET key value... -> StatusReply">
    <group name="pairs" id="1" dimensionType="groupSizeEncoding">
      <data name="key"   id="1" type="varData"/>
      <data name="value" id="2" type="varData"/>
    </group>
  </sbe:message>
  <sbe:message name="MGet" id="64" description="MGET key... -> NullableArrayReply">
    <group name="keys" id="1" dimensionType="groupSizeEncoding">
      <data name="key" id="1" type="varData"/>
    </group>
  </sbe:message>
  <sbe:message name="Echo" id="65" description="ECHO message -> BulkReply">
    <data name="message" id="1" type="varData"/>
  </sbe:message>

  <!-- =================== GOBLIN.* native commands (batch 5, ids 66-76) ========== -->
  <sbe:message name="GoblinCad" id="66" description="GOBLIN.CAD key token -> IntReply (1/0)">
    <data name="key"   id="1" type="varData"/>
    <data name="token" id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinCaExpire" id="67" description="GOBLIN.CAEXPIRE key token ms -> IntReply">
    <field name="ms"    id="1" type="int64"/>
    <data  name="key"   id="2" type="varData"/>
    <data  name="token" id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinCas" id="68" description="GOBLIN.CAS key token value -> StatusReply OK | IntReply 0">
    <data name="key"   id="1" type="varData"/>
    <data name="token" id="2" type="varData"/>
    <data name="value" id="3" type="varData"/>
  </sbe:message>
  <!-- mode: 0 LINEAR, 1 EXP, 2 STEP. Native now/hl/k; reply carries native weights. -->
  <sbe:message name="GoblinTdRescore" id="69" description="GOBLIN.TD_LEADERBOARD_RESCORE -> ScoredArrayReply">
    <field name="now"  id="1" type="double"/>
    <field name="hl"   id="2" type="double"/>
    <field name="k"    id="3" type="int64"/>
    <field name="mode" id="4" type="uint8"/>
    <data  name="key"  id="5" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinIncrEx" id="70" description="GOBLIN.INCREX key seconds -> IntReply | ErrorReply">
    <field name="seconds" id="1" type="int64"/>
    <data  name="key"     id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinZWindow" id="71" description="GOBLIN.ZWINDOW key now window limit member -> IntReply">
    <field name="now"    id="1" type="double"/>
    <field name="window" id="2" type="double"/>
    <field name="limit"  id="3" type="int64"/>
    <data  name="key"    id="4" type="varData"/>
    <data  name="member" id="5" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinIncrBound" id="72" description="GOBLIN.INCRBOUND key delta max -> IntReply">
    <field name="delta" id="1" type="int64"/>
    <field name="max"   id="2" type="int64"/>
    <data  name="key"   id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinDecrPos" id="73" description="GOBLIN.DECRPOS key -> IntReply (new or -1)">
    <data name="key" id="1" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinHCad" id="74" description="GOBLIN.HCAD key field expected -> IntReply (1/0)">
    <data name="key"      id="1" type="varData"/>
    <data name="field"    id="2" type="varData"/>
    <data name="expected" id="3" type="varData"/>
  </sbe:message>
  <!-- value stays a byte string (the exact form stored); the server parses it to a
       double only for the greater-than comparison, matching RESP. -->
  <sbe:message name="GoblinHSetGt" id="75" description="GOBLIN.HSETGT key field value -> IntReply | ErrorReply">
    <data name="key"   id="1" type="varData"/>
    <data name="field" id="2" type="varData"/>
    <data name="value" id="3" type="varData"/>
  </sbe:message>
  <sbe:message name="GoblinClaim" id="76" description="GOBLIN.CLAIM claimKey resultKey token seconds -> BulkReply | NilReply | ErrorReply">
    <field name="seconds"   id="1" type="int64"/>
    <data  name="claimKey"  id="2" type="varData"/>
    <data  name="resultKey" id="3" type="varData"/>
    <data  name="token"     id="4" type="varData"/>
  </sbe:message>

  <!-- ======================== Admin (batch 6, ids 77-78) ======================= -->
  <!-- density <= 0 means "use the default packing density" (the RESP form omits it). -->
  <sbe:message name="GoblinOptimize" id="77" description="GOBLIN.OPTIMIZE key [density] -> IntReply | NilReply | ErrorReply">
    <field name="density" id="1" type="double"/>
    <data  name="key"     id="2" type="varData"/>
  </sbe:message>
  <sbe:message name="Info" id="78" description="INFO -> BulkReply (server/memory fields)"/>

  <!-- ========================= Scripting (batch 7, ids 79-81) ================== -->
  <!-- One message per verb, with a language byte selecting the engine: 0 Lua,
       1 Luau, 2 Wren, 3 Tcl, 4 MicroPython, 5 QuickJS. keys/args are native groups
       (no numkeys to parse). Reply: RespValueReply (the script's RESP result). -->
  <sbe:message name="Eval" id="79" description="EVAL/lang.EVAL script numkeys keys args -> RespValueReply">
    <field name="language" id="1" type="uint8"/>
    <group name="keys" id="2" dimensionType="groupSizeEncoding">
      <data name="key" id="1" type="varData"/>
    </group>
    <group name="args" id="3" dimensionType="groupSizeEncoding">
      <data name="arg" id="1" type="varData"/>
    </group>
    <data name="script" id="4" type="varData"/>
